{
	"name": "NESTrisChamps",
	"version": "1.0.0",
	"description": "",
	"exports": "./index.js",
	"type": "module",
	"scripts": {
		"start": "node -r dotenv/config server.js",
		"session": "node -r dotenv/config scripts/set_session_ids.js",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
		"prepare": "husky install",
		"concat": "node -r dotenv/config scripts/concat_games.js",
		"rerun": "node -r dotenv/config scripts/rerun.js",
		"ctwc-ingest": "IN_SCRIPT=1 node -r dotenv/config scripts/ctwc_reg_to_local_users.js",
		"lint": "npm run lint-be && npm run lint-fe",
		"lint-be": "eslint . --ignore-pattern \"public/**\"",
		"lint-fe": "eslint ./public"
	},
	"keywords": [
		"tetris",
		"classic tetris",
		"statistics",
		"in-real-life events",
		"competition"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1031.0",
		"@aws-sdk/lib-storage": "^3.1031.0",
		"@twurple/api": "^8.1.3",
		"@twurple/auth": "^8.1.3",
		"@twurple/chat": "^8.1.3",
		"connect-pg-simple": "10.0.0",
		"convict": "^6.2.5",
		"cors": "2.8.6",
		"country-list": "^2.4.1",
		"csv-parse": "^6.2.1",
		"dotenv": "^17.4.2",
		"ejs": "5.0.2",
		"express": "5.2.1",
		"express-session": "^1.19.0",
		"glob": "^13.0.6",
		"google-auth-library": "^10.6.2",
		"got": "^15.0.2",
		"lodash": "^4.18.1",
		"nocache": "4.0.0",
		"passport-google-oauth20": "^2.0.0",
		"pg": "^8.20.0",
		"timezones.json": "1.7.2",
		"ulid": "^3.0.2",
		"uuid": "^13.0.0",
		"ws": "^8.20.0"
	},
	"engines": {
		"node": "24.x"
	},
	"devDependencies": {
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jest": "^29.15.2",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"prettier": "^3.8.3",
		"pretty-quick": "^4.2.2"
	}
}
